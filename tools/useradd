#!/usr/bin/env node
import {AuthUsers} from '../src/AuthUsers.js';
import {ToolCli} from '../src/ToolCli.js';

function printHelp() {
  console.log(`Usage: ./tools/useradd [--file PATH] [--replace] USERNAME

Adds a remote web client user to the ScanMeister users file.

Options:
  --file PATH   Users file path. Default: ${AuthUsers.DEFAULT_USERS_FILE}
  --replace     Replace the user if it already exists
`);
}

async function main() {
  const {options, positional} = ToolCli.parseCommonArguments(
    process.argv.slice(2),
    {allowReplace: true, defaultFile: AuthUsers.DEFAULT_USERS_FILE}
  );
  if (options.help) {
    printHelp();
    return;
  }

  const [username] = positional;
  if (!username || positional.length !== 1) {
    printHelp();
    process.exit(1);
  }

  const password = await ToolCli.readHidden("Password: ");
  const confirmation = await ToolCli.readHidden("Confirm password: ");
  if (password !== confirmation) throw new Error("Passwords do not match");

  const users = new AuthUsers(options.file);
  const result = await users.add(username, password, {replace: options.replace});
  console.log(`${result.updated ? "Updated" : "Added"} user '${username}' in ${options.file}.`);
}

main().catch(ToolCli.fail);
