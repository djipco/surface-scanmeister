#!/usr/bin/env node
import {AuthUsers} from '../src/AuthUsers.js';
import {ToolCli} from '../src/ToolCli.js';

function printHelp() {
  console.log(`Usage: ./tools/userlist [--file PATH]

Lists remote web client users from the ScanMeister users file.

Options:
  --file PATH   Users file path. Default: ${AuthUsers.DEFAULT_USERS_FILE}
`);
}

async function main() {
  const {options, positional} = ToolCli.parseCommonArguments(
    process.argv.slice(2),
    {defaultFile: AuthUsers.DEFAULT_USERS_FILE}
  );
  if (options.help) {
    printHelp();
    return;
  }

  if (positional.length !== 0) {
    printHelp();
    process.exit(1);
  }

  const authUsers = new AuthUsers(options.file);
  const users = await authUsers.list();
  if (users.length === 0) {
    console.log(`No users found in ${options.file}.`);
    return;
  }

  users.forEach(user => console.log(user.username));
}

main().catch(ToolCli.fail);
