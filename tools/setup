#!/usr/bin/env node
import {spawnSync} from "node:child_process";
import {existsSync, mkdirSync, readlinkSync, statSync} from "node:fs";
import os from "node:os";
import path from "node:path";
import process from "node:process";
import readline from "node:readline/promises";

const PROJECT_REPOSITORY = "https://github.com/djipco/surface-scanmeister";
const SERVICE_USER = "scanmeister";
const SERVICE_GROUP = "scanmeister";
const TARGET_DIRECTORY = "/home/scanmeister/Desktop/surface-scanmeister";
const SERVICE_SOURCE = "system/scanmeister.service";
const SERVICE_TARGET = "/etc/systemd/system/scanmeister.service";
const AUTOSTART_DIRECTORY = "/home/scanmeister/.config/autostart";
const CLIENT_DESKTOP = "ScanMeister Client.desktop";
const GUERILLA_DESKTOP = "ScanMeister Guerilla.desktop";
const CLIENT_AUTOSTART = path.join(AUTOSTART_DIRECTORY, "scanmeister-client.desktop");
const CERT_DIRECTORY = "/etc/scanmeister/certs";
const CERT_KEY = path.join(CERT_DIRECTORY, "server.key");
const CERT_CRT = path.join(CERT_DIRECTORY, "server.crt");
const USERS_FILE = "/etc/scanmeister/users";
const PI_APPS_DIRECTORY = `/home/${SERVICE_USER}/pi-apps`;
const PI_APPS_MANAGE = path.join(PI_APPS_DIRECTORY, "manage");
const PI_APPS_INSTALL_URL = "https://raw.githubusercontent.com/Botspot/pi-apps/master/install";
const RUSTDESK_APP_NAME = "RustDesk";
const CUSTOM_SANE_SOURCE = "dependencies/sane";
const CUSTOM_SANE_TARGET_BIN = "/usr/local/bin";
const CUSTOM_SANE_TARGET_BACKEND_DIR = "/usr/lib/aarch64-linux-gnu/sane";
const CUSTOM_SANE_GENESYS_BACKEND = "libsane-genesys.so.1.1.1";
const CUSTOM_SANE_GENESYS_LINK = "libsane-genesys.so.1";
const CUSTOM_SANE_REQUIRED_FILES = [
  "bin/scanimage",
  `lib/aarch64-linux-gnu/sane/${CUSTOM_SANE_GENESYS_BACKEND}`
];
const REQUIRED_GROUPS = [
  "adm",
  "lp",
  "dialout",
  "audio",
  "video",
  "plugdev",
  "input",
  "render",
  "netdev",
  "lpadmin",
  "scanner",
  "gpio",
  "i2c",
  "spi"
];
const SYSTEM_PACKAGES = [
  "ca-certificates",
  "curl",
  "git",
  "libcap2-bin",
  "openssl",
  "sane-utils",
  "usbutils",
  "v4l-utils"
];
const EXECUTABLE_FILES = [
  "tools/check",
  "tools/setup",
  "tools/scanners",
  "tools/useradd",
  "tools/userdel",
  "tools/userlist"
];

const args = new Set(process.argv.slice(2));
const dryRun = args.has("--dry-run");
const runAll = args.has("--all");
const help = args.has("--help") || args.has("-h");
const rl = readline.createInterface({input: process.stdin, output: process.stdout});

function printHelp() {
  console.log(`Usage: node tools/setup [--dry-run]
       ./tools/setup [--dry-run]

Interactively prepares a Raspberry Pi for ScanMeister.

The script explains each step, asks before doing it, then verifies the result.

Options:
  --all       Run all setup steps in sequence
  --dry-run   Show commands without changing the system
  -h, --help  Show this help
`);
}

function printHeader(title) {
  console.log(`\n=== ${title} ===`);
}

function formatCommand(command, commandArgs = []) {
  return [command, ...commandArgs].map(part => {
    if (/^[A-Za-z0-9_./:=+@%,-]+$/.test(part)) return part;
    return `'${String(part).replaceAll("'", "'\\''")}'`;
  }).join(" ");
}

function run(command, commandArgs = [], options = {}) {
  let actualCommand = command;
  let actualArgs = commandArgs;

  if (options.user && os.userInfo().username !== options.user) {
    actualCommand = "sudo";
    actualArgs = ["-u", options.user, "-H", command, ...commandArgs];
  } else if (options.sudo) {
    actualCommand = "sudo";
    actualArgs = [command, ...commandArgs];
  }

  if (!options.silent) {
    console.log(`$ ${formatCommand(actualCommand, actualArgs)}`);
  }

  if (dryRun) {
    if (!options.silent) {
      console.log("DRY RUN: command not executed.");
    }
    return {ok: true, status: 0, stdout: "", stderr: ""};
  }

  const result = spawnSync(actualCommand, actualArgs, {
    cwd: options.cwd,
    encoding: "utf8",
    stdio: options.capture ? "pipe" : "inherit"
  });

  return {
    ok: result.status === 0,
    status: result.status,
    stdout: result.stdout || "",
    stderr: result.stderr || ""
  };
}

function capture(command, commandArgs = [], options = {}) {
  return run(command, commandArgs, {...options, capture: true});
}

function commandExists(command) {
  return capture("sh", ["-lc", `command -v ${command}`]).ok;
}

function fileExists(file) {
  try {
    return existsSync(file) && statSync(file).isFile();
  } catch {
    return false;
  }
}

function directoryExists(directory) {
  try {
    return existsSync(directory) && statSync(directory).isDirectory();
  } catch {
    return false;
  }
}

function isExecutable(file) {
  try {
    return Boolean(statSync(file).mode & 0o111);
  } catch {
    return false;
  }
}

async function confirm(question) {
  const answer = (await rl.question(`${question} [y/N] `)).trim().toLowerCase();
  return answer === "y" || answer === "yes" || answer === "o" || answer === "oui";
}

function ok(message) {
  console.log(`[OK ] ${message}`);
}

function warn(message) {
  console.log(`[WARN] ${message}`);
}

function fail(message) {
  console.log(`[FAIL] ${message}`);
}

async function runStep(title, description, action, verify) {
  printHeader(title);
  console.log(description.trim());
  const shouldRun = await confirm("Run this step?");

  if (shouldRun) {
    await action();
  } else {
    console.log("Skipped.");
  }

  const result = await verify();
  if (result.ok) {
    ok(result.message);
  } else if (shouldRun) {
    fail(result.message);
  } else {
    warn(result.message);
  }
}

async function chooseSetupStep(steps) {
  printHeader("Setup menu");
  steps.forEach((step, index) => {
    console.log(`  ${index + 1}. ${step.title}`);
  });
  console.log("  A. Run all steps");
  console.log("  Q. Quit");

  while (true) {
    const answer = (await rl.question("Choose an action: ")).trim().toLowerCase();
    if (answer === "q" || answer === "quit" || answer === "exit") return null;
    if (answer === "a" || answer === "all") return "all";

    const number = Number(answer);
    if (Number.isInteger(number) && number >= 1 && number <= steps.length) {
      return number - 1;
    }

    console.log(`Please enter a number between 1 and ${steps.length}, A, or Q.`);
  }
}

function nodeMajorVersion() {
  const result = capture("node", ["--version"]);
  if (!result.ok) return 0;
  const match = result.stdout.trim().match(/^v?(\d+)/);
  return match ? Number(match[1]) : 0;
}

function realNodePath() {
  const result = capture("sh", ["-lc", 'readlink -f "$(command -v node)"']);
  return result.ok ? result.stdout.trim() : "";
}

function getGroups(username) {
  const result = capture("id", ["-nG", username]);
  return result.ok ? result.stdout.trim().split(/\s+/).filter(Boolean) : [];
}

function existingGroups(groups) {
  return groups.filter(group => capture("getent", ["group", group]).ok);
}

function customSanePath(relativePath = "") {
  return path.join(TARGET_DIRECTORY, CUSTOM_SANE_SOURCE, relativePath);
}

function missingCustomSaneFiles() {
  return CUSTOM_SANE_REQUIRED_FILES.filter(relativePath => !fileExists(customSanePath(relativePath)));
}

function piAppsInstalled() {
  return fileExists(PI_APPS_MANAGE);
}

function rustDeskInstalled() {
  return capture("sh", ["-lc", "command -v rustdesk >/dev/null 2>&1 || dpkg-query -W rustdesk >/dev/null 2>&1"]).ok;
}

function configureX11ForRustDesk() {
  if (!commandExists("raspi-config")) {
    warn("raspi-config is not available; cannot switch the desktop session to X11 automatically.");
    return false;
  }

  run("raspi-config", ["nonint", "do_wayland", "W1"], {sudo: true});
  console.log("X11 desktop mode requested. Reboot or log out/in for the change to take effect.");
  return true;
}

async function chooseAutostartMode() {
  console.log("Choose which client should start automatically:");
  console.log("  1. Normal client");
  console.log("  2. Guerilla client");
  console.log("  3. None");

  while (true) {
    const answer = (await rl.question("Autostart choice [1/2/3] ")).trim().toLowerCase();
    if (answer === "1" || answer === "normal" || answer === "client") return "normal";
    if (answer === "2" || answer === "guerilla" || answer === "guerrilla") return "guerilla";
    if (answer === "3" || answer === "none" || answer === "no" || answer === "n") return "none";
    console.log("Please enter 1, 2, or 3.");
  }
}

async function verifyAutostart(expectedMode) {
  if (expectedMode === "unchanged") {
    return {
      ok: true,
      message: "Client autostart was left unchanged."
    };
  }

  if (expectedMode === "none") {
    return {
      ok: !fileExists(CLIENT_AUTOSTART),
      message: !fileExists(CLIENT_AUTOSTART)
        ? "No client autostart entry is configured."
        : `${CLIENT_AUTOSTART} still exists.`
    };
  }

  if (!fileExists(CLIENT_AUTOSTART)) {
    return {ok: false, message: `${CLIENT_AUTOSTART} does not exist.`};
  }

  try {
    const target = readlinkSync(CLIENT_AUTOSTART);
    const expectedLauncher = expectedMode === "guerilla" ? GUERILLA_DESKTOP : CLIENT_DESKTOP;
    return {
      ok: target.endsWith(expectedLauncher),
      message: `${CLIENT_AUTOSTART} points to ${target}.`
    };
  } catch {
    return {ok: true, message: `${CLIENT_AUTOSTART} exists.`};
  }
}

function verifyEnvironment() {
  if (process.platform !== "linux") {
    fail(`This setup assistant must run on Linux/Raspberry Pi, not ${process.platform}.`);
    process.exitCode = 1;
    return false;
  }

  return true;
}

function ensureProjectToolsExecutable() {
  run("chmod", ["+x", ...EXECUTABLE_FILES], {cwd: process.cwd(), silent: true});

  const missing = EXECUTABLE_FILES.filter(file => !fileExists(path.join(process.cwd(), file)));
  const notExecutable = EXECUTABLE_FILES.filter(file => fileExists(path.join(process.cwd(), file)) && !isExecutable(path.join(process.cwd(), file)));

  if (missing.length > 0) {
    fail(`Missing required project tools: ${missing.join(", ")}.`);
    process.exitCode = 1;
    return false;
  }

  if (notExecutable.length > 0) {
    if (dryRun) {
      return true;
    }

    fail(`Some project tools are not executable: ${notExecutable.join(", ")}.`);
    process.exitCode = 1;
    return false;
  }

  return true;
}

async function main() {
  if (help) {
    printHelp();
    return;
  }

  console.log("ScanMeister initial setup");
  if (dryRun) console.log("Dry run: yes");

  if (!verifyEnvironment()) {
    return;
  }

  if (!ensureProjectToolsExecutable()) {
    return;
  }

  const setupState = {
    autostartMode: "unchanged"
  };
  const steps = [];
  const addStep = (title, description, action, verify) => {
    steps.push({
      title,
      run: () => runStep(title, description, action, verify)
    });
  };

  addStep(
    "Create 'scanmeister' user and assign necessary groups",
    `The systemd service runs as ${SERVICE_USER}:${SERVICE_GROUP}. This step creates the user if missing and adds it to groups used for scanners, USB, graphics, GPIO, I2C and related hardware.

Requested groups:
${REQUIRED_GROUPS.join(", ")}`,
    async () => {
      if (capture("id", [SERVICE_USER]).ok) {
        console.log(`${SERVICE_USER} already exists.`);
      } else {
        run("useradd", ["-m", "-s", "/bin/bash", SERVICE_USER], {sudo: true});
      }
      const groups = existingGroups(REQUIRED_GROUPS);
      if (groups.length === 0) {
        warn("None of the requested groups exist on this system.");
        return;
      }
      run("usermod", ["-aG", groups.join(","), SERVICE_USER], {sudo: true});
    },
    async () => {
      if (!capture("id", [SERVICE_USER]).ok) {
        return {
          ok: false,
          message: `${SERVICE_USER} does not exist.`
        };
      }

      const groups = existingGroups(REQUIRED_GROUPS);
      const current = getGroups(SERVICE_USER);
      const missing = groups.filter(group => !current.includes(group));
      return {
        ok: missing.length === 0,
        message: missing.length === 0
          ? `${SERVICE_USER} exists and is in all existing requested groups.`
          : `${SERVICE_USER} is missing groups: ${missing.join(", ")}. Log out/in may be required.`
      };
    }
  );

  addStep(
    "Install required system packages",
    `This installs packages used by ScanMeister and the setup process:
${SYSTEM_PACKAGES.join(", ")}`,
    async () => {
      run("apt-get", ["update"], {sudo: true});
      run("apt-get", ["install", "-y", ...SYSTEM_PACKAGES], {sudo: true});
    },
    async () => {
      const missing = SYSTEM_PACKAGES.filter(pkg => !capture("dpkg-query", ["-W", "-f=${Status}", pkg]).stdout.includes("install ok installed"));
      return {
        ok: missing.length === 0,
        message: missing.length === 0
          ? "All base packages are installed."
          : `Missing packages: ${missing.join(", ")}.`
      };
    }
  );

  addStep(
    "Install customized SANE build",
    `This installs the custom ScanMeister SANE build from:
${customSanePath()}

Required files:
${CUSTOM_SANE_REQUIRED_FILES.join("\n")}

The custom scanimage command is installed under /usr/local/bin.
The patched genesys backend replaces the system backend under /usr/lib/aarch64-linux-gnu/sane.`,
    async () => {
      const missing = missingCustomSaneFiles();
      if (missing.length > 0) {
        warn(`Custom SANE files are incomplete. Missing: ${missing.join(", ")}.`);
        return;
      }

      run("mkdir", ["-p", CUSTOM_SANE_TARGET_BIN, CUSTOM_SANE_TARGET_BACKEND_DIR], {sudo: true});
      run("cp", ["-a", customSanePath("bin/scanimage"), CUSTOM_SANE_TARGET_BIN], {sudo: true});
      run("cp", ["-a", customSanePath(`lib/aarch64-linux-gnu/sane/${CUSTOM_SANE_GENESYS_BACKEND}`), CUSTOM_SANE_TARGET_BACKEND_DIR], {sudo: true});
      run("ln", ["-sf", CUSTOM_SANE_GENESYS_BACKEND, path.join(CUSTOM_SANE_TARGET_BACKEND_DIR, CUSTOM_SANE_GENESYS_LINK)], {sudo: true});
      run("chmod", ["755", path.join(CUSTOM_SANE_TARGET_BIN, "scanimage")], {sudo: true});
      run("chmod", ["644", path.join(CUSTOM_SANE_TARGET_BACKEND_DIR, CUSTOM_SANE_GENESYS_BACKEND)], {sudo: true});
      run("ldconfig", [], {sudo: true});
    },
    async () => {
      const missing = missingCustomSaneFiles();
      if (missing.length > 0) {
        return {
          ok: false,
          message: `Custom SANE dependency is incomplete. Missing: ${missing.join(", ")}.`
        };
      }

      const scanimagePath = capture("sh", ["-lc", "command -v scanimage"]);
      const version = capture("scanimage", ["-V"]);
      const backendInstalled = fileExists(path.join(CUSTOM_SANE_TARGET_BACKEND_DIR, CUSTOM_SANE_GENESYS_BACKEND));
      return {
        ok: scanimagePath.stdout.trim() === path.join(CUSTOM_SANE_TARGET_BIN, "scanimage") && backendInstalled && version.ok,
        message: scanimagePath.stdout.trim() === path.join(CUSTOM_SANE_TARGET_BIN, "scanimage") && backendInstalled
          ? `Custom scanimage and genesys backend are active: ${version.stdout.trim() || "version read successfully"}.`
          : `scanimage is ${scanimagePath.stdout.trim() || "not found"} and genesys backend installed: ${backendInstalled ? "yes" : "no"}.`
      };
    }
  );

  addStep(
    "Install Node.js and configure port binding permissions",
    "ScanMeister requires Node.js 20 or newer. This step installs NodeSource LTS setup if the installed Node is too old or missing, then allows Node to bind ports 80 and 443 without running as root.",
    async () => {
      if (nodeMajorVersion() >= 20) {
        console.log(`Node is already acceptable: ${capture("node", ["--version"]).stdout.trim()}`);
      } else {
        run("sh", ["-lc", "curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -"]);
        run("apt-get", ["install", "-y", "nodejs"], {sudo: true});
      }

      const nodePath = realNodePath();
      if (!nodePath) {
        warn("Could not resolve node path; cannot apply cap_net_bind_service.");
        return;
      }
      run("setcap", ["cap_net_bind_service=+ep", nodePath], {sudo: true});
    },
    async () => {
      const versionOk = nodeMajorVersion() >= 20;
      const nodeVersion = capture("node", ["--version"]).stdout.trim();
      const nodePath = realNodePath();
      const caps = nodePath ? capture("getcap", [nodePath]) : {ok: false, stdout: ""};
      const capOk = caps.stdout.includes("cap_net_bind_service=ep");
      const problems = [];

      if (!versionOk) problems.push("Node.js 20 or newer is not available");
      if (!capOk) problems.push("cap_net_bind_service is not set on Node");

      return {
        ok: problems.length === 0,
        message: problems.length === 0
          ? `Node.js is ${nodeVersion}; ${caps.stdout.trim()}.`
          : problems.join("; ")
      };
    }
  );

  addStep(
    "Prepare ScanMeister project and runtime files",
    `Target directory:
${TARGET_DIRECTORY}

If it does not exist, this clones ${PROJECT_REPOSITORY}.
If it exists, this offers a git pull only when the worktree is clean.
Then it installs Node dependencies and prepares runtime directories/configuration:
${path.join(TARGET_DIRECTORY, "logs")}
${path.join(TARGET_DIRECTORY, "scans")}
${path.dirname(USERS_FILE)}
${CERT_DIRECTORY}
${USERS_FILE}`,
    async () => {
      if (!directoryExists(TARGET_DIRECTORY)) {
        mkdirSync(path.dirname(TARGET_DIRECTORY), {recursive: true});
        run("git", ["clone", PROJECT_REPOSITORY, TARGET_DIRECTORY], {sudo: os.userInfo().username !== SERVICE_USER});
        run("chown", ["-R", `${SERVICE_USER}:${SERVICE_GROUP}`, TARGET_DIRECTORY], {sudo: true});
      } else {
        const status = capture("git", ["status", "--short"], {cwd: TARGET_DIRECTORY});
        if (!status.ok) {
          warn(`${TARGET_DIRECTORY} exists but is not a git repository.`);
        } else if (status.stdout.trim()) {
          warn("Project has local changes. Skipping git pull to avoid overwriting work.");
        } else {
          run("git", ["pull"], {cwd: TARGET_DIRECTORY});
        }
      }

      if (fileExists(path.join(TARGET_DIRECTORY, "package.json"))) {
        const npmCommand = fileExists(path.join(TARGET_DIRECTORY, "package-lock.json")) ? "ci" : "install";
        run("npm", [npmCommand], {cwd: TARGET_DIRECTORY});
      } else {
        warn(`${TARGET_DIRECTORY}/package.json is missing; skipping npm install.`);
      }

      ["logs", "scans"].forEach(directory => {
        const fullPath = path.join(TARGET_DIRECTORY, directory);
        run("mkdir", ["-p", fullPath], {sudo: true});
        run("chown", ["-R", `${SERVICE_USER}:${SERVICE_GROUP}`, fullPath], {sudo: true});
      });

      run("mkdir", ["-p", path.dirname(USERS_FILE), CERT_DIRECTORY], {sudo: true});

      if (!fileExists(USERS_FILE)) {
        const addUser = await confirm("No users file exists. Add first remote user now?");
        if (addUser) run("./tools/useradd", ["admin"], {cwd: TARGET_DIRECTORY, sudo: true});
      }

      if (fileExists(USERS_FILE)) {
        run("chown", ["root:scanmeister", USERS_FILE], {sudo: true});
        run("chmod", ["640", USERS_FILE], {sudo: true});
      }
    },
    async () => {
      const projectExists = fileExists(path.join(TARGET_DIRECTORY, "ScanMeister.js"));
      const dependenciesInstalled = directoryExists(path.join(TARGET_DIRECTORY, "node_modules"));
      const missingDirectories = [
        path.join(TARGET_DIRECTORY, "logs"),
        path.join(TARGET_DIRECTORY, "scans"),
        path.dirname(USERS_FILE),
        CERT_DIRECTORY
      ].filter(directory => !directoryExists(directory));
      const problems = [];

      if (!projectExists) problems.push(`project is missing at ${TARGET_DIRECTORY}`);
      if (!dependenciesInstalled) problems.push("node_modules is missing");
      if (missingDirectories.length > 0) problems.push(`missing directories: ${missingDirectories.join(", ")}`);
      if (!fileExists(USERS_FILE)) problems.push(`${USERS_FILE} does not exist; remote HTTPS access will be refused`);

      return {
        ok: problems.length === 0,
        message: problems.length === 0
          ? `Project, Node dependencies, runtime directories, and remote users file are ready at ${TARGET_DIRECTORY}.`
          : problems.join("; ")
      };
    }
  );

  addStep(
    "Create HTTPS certificate",
    `This creates a self-signed certificate unless both files already exist:
${CERT_KEY}
${CERT_CRT}`,
    async () => {
      if (fileExists(CERT_KEY) && fileExists(CERT_CRT)) {
        console.log("Certificate files already exist.");
      } else {
        run("mkdir", ["-p", CERT_DIRECTORY], {sudo: true});
        run("openssl", [
          "req", "-x509", "-newkey", "rsa:4096", "-sha256", "-days", "3650", "-nodes",
          "-keyout", CERT_KEY,
          "-out", CERT_CRT,
          "-subj", "/CN=scanmeister.local",
          "-addext", "subjectAltName=DNS:localhost,DNS:scanmeister.local,DNS:scanmeister01.local,IP:127.0.0.1"
        ], {sudo: true});
      }
      run("chown", ["root:scanmeister", CERT_KEY, CERT_CRT], {sudo: true});
      run("chmod", ["640", CERT_KEY, CERT_CRT], {sudo: true});
    },
    async () => ({
      ok: fileExists(CERT_KEY) && fileExists(CERT_CRT),
      message: fileExists(CERT_KEY) && fileExists(CERT_CRT)
        ? "HTTPS certificate files exist."
        : "HTTPS certificate files are missing."
    })
  );

  addStep(
    "Install and enable systemd scanmeister.service",
    `This copies ${SERVICE_SOURCE} to ${SERVICE_TARGET}, reloads systemd, and enables scanmeister.service.`,
    async () => {
      run("cp", [path.join(TARGET_DIRECTORY, SERVICE_SOURCE), SERVICE_TARGET], {sudo: true});
      run("systemctl", ["daemon-reload"], {sudo: true});
      run("systemctl", ["enable", "scanmeister.service"], {sudo: true});
      const startNow = await confirm("Start or restart scanmeister.service now?");
      if (startNow) run("systemctl", ["restart", "scanmeister.service"], {sudo: true});
    },
    async () => {
      const enabled = capture("systemctl", ["is-enabled", "scanmeister.service"]);
      return {
        ok: fileExists(SERVICE_TARGET) && enabled.ok,
        message: fileExists(SERVICE_TARGET)
          ? `Service file installed. Enabled: ${enabled.ok ? "yes" : "no"}.`
          : `${SERVICE_TARGET} is missing.`
      };
    }
  );

  addStep(
    "Configure client autostart",
    `This configures what the ${SERVICE_USER} desktop session opens automatically:
normal client, Guerilla client, or no client autostart.`,
    async () => {
      setupState.autostartMode = await chooseAutostartMode();
      run("mkdir", ["-p", AUTOSTART_DIRECTORY], {sudo: true});
      run("chown", ["-R", `${SERVICE_USER}:${SERVICE_GROUP}`, AUTOSTART_DIRECTORY], {sudo: true});

      if (setupState.autostartMode === "none") {
        run("rm", ["-f", CLIENT_AUTOSTART], {sudo: os.userInfo().username !== SERVICE_USER});
        return;
      }

      const desktopFile = setupState.autostartMode === "guerilla" ? GUERILLA_DESKTOP : CLIENT_DESKTOP;
      const launcher = path.join(TARGET_DIRECTORY, desktopFile);
      run("ln", ["-sf", launcher, CLIENT_AUTOSTART], {sudo: os.userInfo().username !== SERVICE_USER});
      run("chown", ["-h", `${SERVICE_USER}:${SERVICE_GROUP}`, CLIENT_AUTOSTART], {sudo: true});
    },
    async () => verifyAutostart(setupState.autostartMode)
  );

  addStep(
    "Enable SSH",
    "This uses raspi-config non-interactive commands when available.",
    async () => {
      if (!commandExists("raspi-config")) {
        warn("raspi-config is not available; cannot enable SSH automatically.");
        return;
      }
      run("raspi-config", ["nonint", "do_ssh", "0"], {sudo: true});
    },
    async () => {
      if (!commandExists("raspi-config")) {
        return {ok: false, message: "raspi-config is not available; SSH status was not changed."};
      }
      const ssh = capture("systemctl", ["is-enabled", "ssh"]);
      return {
        ok: ssh.ok,
        message: `SSH enabled: ${ssh.ok ? "yes" : "unknown/no"}.`
      };
    }
  );

  addStep(
    "Install RustDesk and configure X11",
    `This installs RustDesk through Pi-Apps for remote support and requests X11 desktop mode.

RustDesk can connect but show a black screen on Wayland. X11 is the recommended desktop mode for ScanMeister remote support.

Pi-Apps will be installed for the ${SERVICE_USER} user if it is missing:
${PI_APPS_DIRECTORY}

RustDesk app name:
${RUSTDESK_APP_NAME}`,
    async () => {
      if (!piAppsInstalled()) {
        run("sh", ["-lc", `curl -fsSL ${PI_APPS_INSTALL_URL} | bash`], {user: SERVICE_USER});
      }

      if (!piAppsInstalled()) {
        warn(`Pi-Apps was not found at ${PI_APPS_MANAGE}; cannot install ${RUSTDESK_APP_NAME}.`);
        return;
      }

      if (rustDeskInstalled()) {
        console.log("RustDesk already appears to be installed.");
      } else {
        run(PI_APPS_MANAGE, ["install", RUSTDESK_APP_NAME], {user: SERVICE_USER});
      }

      configureX11ForRustDesk();
    },
    async () => ({
      ok: piAppsInstalled() && rustDeskInstalled(),
      message: piAppsInstalled() && rustDeskInstalled()
        ? "Pi-Apps and RustDesk are installed. X11 was requested if raspi-config was available; reboot or log out/in may be required."
        : `Pi-Apps installed: ${piAppsInstalled() ? "yes" : "no"}, RustDesk installed: ${rustDeskInstalled() ? "yes" : "no"}.`
    })
  );

  if (runAll) {
    for (const step of steps) {
      await step.run();
    }
  } else {
    const choice = await chooseSetupStep(steps);
    if (choice === null) {
      console.log("Setup cancelled.");
      return;
    }

    if (choice === "all") {
      for (const step of steps) {
        await step.run();
      }
    } else {
      await steps[choice].run();
    }
  }

  console.log("\nSetup finished.");
  console.log("Useful URLs:");
  console.log("  https://localhost");
  console.log("  https://scanmeister01.local");
}

main()
  .catch(error => {
    console.error(`Error: ${error.message || error}`);
    process.exitCode = 1;
  })
  .finally(() => {
    rl.close();
  });
